<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Shopper.Models"
             x:Class="Shopper.ProductList"
             Title="ProductList">
    <VerticalStackLayout>
        <RefreshView Grid.Row="1" 
                     IsRefreshing="{Binding IsRefreshing}" 
                     Command="{Binding LoadProductsCommand}">

            <CollectionView ItemsSource="{Binding Products}"
                            SelectionMode="None"
                            Margin="10">

                <!-- Definicja siatki (Layout) - 2 kolumny automatycznie dopasowane -->
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" 
                                     Span="2" 
                                     HorizontalItemSpacing="10" 
                                     VerticalItemSpacing="10"/>
                </CollectionView.ItemsLayout>

                <!-- Wygląd pojedynczej karty produktu -->
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Product">
                        <Border StrokeShape="RoundRectangle 12"
                                StrokeThickness="1"
                                Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
                                Padding="10"
                                HeightRequest="280">

                            <!-- Obsługa kliknięcia w kartę -->
                            <!--<Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeBinding AncestorType={x:Type viewmodels:ProductsViewModel}}, Path=SelectProductCommand}" 
                                                      CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>-->

                            <Grid RowDefinitions="*, Auto, Auto, Auto">

                                <!-- Zdjęcie produktu z FakeStore API -->
                                <Image Grid.Row="0" 
                                       Source="{Binding Image}" 
                                       Aspect="AspectFit"
                                       HorizontalOptions="Center" 
                                       VerticalOptions="Center"
                                       HeightRequest="130"
                                       Margin="0,0,0,10"/>

                                <!-- Kategoria produktu -->
                                <Label Grid.Row="1" 
                                       Text="{Binding Category}" 
                                       FontSize="10" 
                                       TextColor="Gray" 
                                       FontAttributes="Italic"
                                       TextTransform="Uppercase"/>

                                <!-- Tytuł produktu (max 2 linie, ucięty jeśli za długi) -->
                                <Label Grid.Row="2" 
                                       Text="{Binding Title}" 
                                       FontAttributes="Bold" 
                                       FontSize="14"
                                       LineBreakMode="TailTruncation" 
                                       MaxLines="2"
                                       Margin="0,2,0,5"
                                       TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"/>

                                <!-- Cena formatowana lokalnie -->
                                <Label Grid.Row="3" 
                                       Text="{Binding Price, StringFormat='{0:F2} zł'}" 
                                       TextColor="{StaticResource Primary}" 
                                       FontAttributes="Bold" 
                                       FontSize="16"
                                       VerticalOptions="EndAndExpand"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <!-- Widok w przypadku braku produktów -->
                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Padding="30">
                        <Label Text="Brak dostępnych produktów." 
                               HorizontalTextAlignment="Center" 
                               FontSize="16"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

            </CollectionView>
        </RefreshView>
    </VerticalStackLayout>
</ContentPage>