<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Shopper.Models"
             x:Class="Shopper.Views.ShoppingCartPage"
             Title="Koszyk">
    <Grid RowDefinitions="*, Auto">

        <CollectionView Grid.Row="0" 
                        x:Name="CartCollectionView"
                        Margin="10"
                        SelectionMode="None">

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:CartItem">
                    <Border StrokeShape="RoundRectangle 12"
                            StrokeThickness="1"
                            Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
                            Padding="10"
                            Margin="0,0,0,10">

                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="15">

                            <HorizontalStackLayout Grid.Column="0" Spacing="12" VerticalOptions="Center">
                                <Border StrokeShape="RoundRectangle 8" 
                                        StrokeThickness="0"
                                        WidthRequest="70" 
                                        HeightRequest="70"
                                        BackgroundColor="#FFFFFF"
                                        VerticalOptions="Center">
                                    <Image Source="{Binding Product.Image}" 
                                           Aspect="AspectFit"/>
                                </Border>

                                <VerticalStackLayout VerticalOptions="Center" WidthRequest="150">
                                    <Label Text="{Binding Product.Title}" 
                                           FontAttributes="Bold" 
                                           FontSize="14" 
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation"
                                           TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"/>

                                    <Label Text="{Binding Product.Price, StringFormat='Cena: {0:F2} zł'}" 
                                           FontSize="12" 
                                           TextColor="Gray"
                                           Margin="0,2,0,0"/>
                                </VerticalStackLayout>
                            </HorizontalStackLayout>

                            <VerticalStackLayout Grid.Column="1" HorizontalOptions="End" VerticalOptions="Center" Spacing="8">

                                <Label Text="{Binding TotalPrice, StringFormat='{0:F2} zł'}" 
                                       TextColor="{StaticResource Primary}" 
                                       FontAttributes="Bold" 
                                       FontSize="16"
                                       HorizontalOptions="End"/>

                                <HorizontalStackLayout Spacing="5" HorizontalOptions="End">
                                    <Button Text="-"
                                            WidthRequest="32"
                                            HeightRequest="32"
                                            CornerRadius="16"
                                            Padding="0"
                                            FontSize="14"
                                            BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2D2D2D}"
                                            TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                            Clicked="OnDecreaseQuantityClicked"
                                            CommandParameter="{Binding .}"/>

                                    <Label Text="{Binding Quantity}" 
                                           VerticalOptions="Center" 
                                           HorizontalOptions="Center"
                                           WidthRequest="30"
                                           HorizontalTextAlignment="Center"
                                           FontAttributes="Bold"
                                           FontSize="14"
                                           TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"/>

                                    <Button Text="+"
                                            WidthRequest="32"
                                            HeightRequest="32"
                                            CornerRadius="16"
                                            Padding="0"
                                            FontSize="14"
                                            BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2D2D2D}"
                                            TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                            Clicked="OnIncreaseQuantityClicked"
                                            CommandParameter="{Binding .}"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Padding="30" Spacing="10">
                    <Label Text="🛒" FontSize="50" HorizontalTextAlignment="Center"/>
                    <Label Text="Twój koszyk jest pusty." HorizontalTextAlignment="Center" FontSize="16"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>

        <Border Grid.Row="1" 
                StrokeShape="RoundRectangle 16,16,0,0"
                StrokeThickness="1"
                Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                BackgroundColor="{AppThemeBinding Light=#F9F9F9, Dark=#1A1A1A}"
                Padding="20,15"
                Margin="0">

            <VerticalStackLayout Spacing="15">
                <Grid ColumnDefinitions="*, Auto">
                    <Label Grid.Column="0" Text="Razem do zapłaty:" FontSize="16" VerticalOptions="Center" TextColor="{AppThemeBinding Light=#555555, Dark=#CCCCCC}"/>
                    <Label Grid.Column="1" x:Name="CartTotalLabel" Text="0.00 zł" FontSize="20" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"/>
                </Grid>

                <Button Text="Przejdź do kasy" 
                        CornerRadius="8"
                        HeightRequest="50"
                        FontAttributes="Bold"
                        FontSize="16"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        Clicked="OnCheckoutClicked"/>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>