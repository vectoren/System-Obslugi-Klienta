<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Shopper.Views.AccountPage"
             Title="Moje Konto"
             BackgroundColor="{AppThemeBinding Light=#F5F5F7, Dark=#121212}">

    <ScrollView>
        <Grid ColumnDefinitions="*, 400, *" Padding="0,20">
            <VerticalStackLayout Grid.Column="1" Spacing="20" Margin="20,0">

                <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}" Padding="20">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.05"/>
                    </Border.Shadow>

                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="20" VerticalOptions="Center">
                        <Border Grid.Column="0" WidthRequest="80" HeightRequest="80" StrokeShape="RoundRectangle 40" BackgroundColor="#512BD4" StrokeThickness="0">
                            <Label Text="JK" TextColor="White" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>

                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="{Binding fullName}" FontSize="22" FontAttributes="Bold" TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
                            <Label Text="{Binding email}" FontSize="14" TextColor="Gray"/>
                            <Label Text="{Binding accountCreationDate, StringFormat='Klient od: {0}'}" FontSize="12" TextColor="Gray" FontAttributes="Italic" Margin="0,5,0,0"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Label Text="Ustawienia Profilu" FontAttributes="Bold" FontSize="16" Margin="5,10,0,0" TextColor="{StaticResource Primary}"/>

                <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}" Padding="20">
                    <Grid RowDefinitions="Auto, Auto, Auto, Auto" RowSpacing="12">

                        <Grid Grid.Row="0" ColumnDefinitions="*, *" ColumnSpacing="10">
                            <VerticalStackLayout Grid.Column="0" Spacing="5">
                                <Label Text="Imię" FontSize="12" TextColor="Gray"/>
                                <Border StrokeShape="RoundRectangle 8" StrokeThickness="1" Stroke="LightGray" Padding="10,2">
                                    <Entry Text="{Binding firstName}" TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="5">
                                <Label Text="Nazwisko" FontSize="12" TextColor="Gray"/>
                                <Border StrokeShape="RoundRectangle 8" StrokeThickness="1" Stroke="LightGray" Padding="10,2">
                                    <Entry Text="{Binding lastName}" TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <VerticalStackLayout Grid.Row="1" Spacing="5">
                            <Label Text="Adres E-mail" FontSize="12" TextColor="Gray"/>
                            <Border StrokeShape="RoundRectangle 8" StrokeThickness="1" Stroke="LightGray" Padding="10,2">
                                <Entry Text="{Binding email}" Keyboard="Email" TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Row="2" Spacing="5">
                            <Label Text="Nowe Hasło" FontSize="12" TextColor="Gray"/>
                            <Border StrokeShape="RoundRectangle 8" StrokeThickness="1" Stroke="LightGray" Padding="10,2">
                                <Entry Placeholder="••••••••" IsPassword="True" TextColor="{AppThemeBinding Light=Black, Dark=White}" Text="{Binding password}"/>
                            </Border>
                        </VerticalStackLayout>

                        <Button Grid.Row="3" 
                                Text="Zaktualizuj informacje" 
                                CornerRadius="8" 
                                HeightRequest="45"
                                BackgroundColor="#512BD4" 
                                TextColor="White" 
                                FontAttributes="Bold"
                                Margin="0,10,0,0"
                                Clicked="UpdateUserData"/>
                    </Grid>
                </Border>

                <Label Text="Zarządzanie kontem" FontAttributes="Bold" FontSize="16" Margin="5,10,0,0" TextColor="Gray"/>

                <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}" Padding="20">
                    <VerticalStackLayout Spacing="10">

                        <Button Text="Wyloguj się" 
                                BackgroundColor="Transparent" 
                                BorderColor="Gray" 
                                BorderWidth="1"
                                TextColor="{AppThemeBinding Light=Black, Dark=White}" 
                                CornerRadius="8" 
                                HeightRequest="45"
                                Clicked="LogoutUser"
                                />

                        <Button Text="Usuń konto" 
                                BackgroundColor="#FF3B30" 
                                TextColor="White" 
                                CornerRadius="8" 
                                HeightRequest="45"
                                FontAttributes="Bold"
                                Clicked="DeleteUser"
                                />

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>