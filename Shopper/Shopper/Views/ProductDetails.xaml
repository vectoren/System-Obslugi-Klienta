<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Shopper.Views.ProductDetails"
             Title="Szczegóły produktu">

    <Grid RowDefinitions="*, Auto" ColumnDefinitions="*">

        <ScrollView Grid.Row="0">
            <Grid RowDefinitions="350, Auto, Auto, Auto, Auto, *" 
                  ColumnDefinitions="*, *"
                  Padding="20" 
                  RowSpacing="10">

                <Image x:Name="ProductImage"
                       Grid.Row="0" Grid.ColumnSpan="2"
                       Aspect="AspectFit"
                       VerticalOptions="Center" />

                <Label x:Name="TitleLabel"
                       Grid.Row="1" Grid.ColumnSpan="2"
                       FontSize="26"
                       FontAttributes="Bold"
                       Margin="0,10,0,0" />

                <Label x:Name="CategoryLabel"
                       Grid.Row="2" Grid.Column="0"
                       FontSize="14"
                       TextColor="Gray"
                       VerticalOptions="Center" />

                <Label x:Name="PriceLabel"
                       Grid.Row="2" Grid.Column="1"
                       FontSize="22"
                       TextColor="{StaticResource Primary}"
                       FontAttributes="Bold"
                       HorizontalOptions="End" />

                <BoxView Grid.Row="3" Grid.ColumnSpan="2"
                         HeightRequest="1" Color="Silver" Margin="0,5" />

                <Label Text="O produkcie"
                       Grid.Row="4" Grid.ColumnSpan="2"
                       FontSize="18" FontAttributes="Bold" />

                <Label x:Name="DescriptionLabel"
                       Grid.Row="5" Grid.ColumnSpan="2"
                       FontSize="16"
                       TextColor="#444" />
            </Grid>
        </ScrollView>

        <Border Grid.Row="1" 
                Padding="20,10" 
                StrokeThickness="0" 
                BackgroundColor="White">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,-2" Opacity="0.1" />
            </Border.Shadow>

            <Button Text="DODAJ DO KOSZYKA"
                    HeightRequest="55"
                    CornerRadius="10"
                    FontAttributes="Bold"
                    Clicked="AddToCart"/>
        </Border>

    </Grid>
</ContentPage>