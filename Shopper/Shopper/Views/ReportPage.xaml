<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Shopper.Views.ReportPage"
             Title="ReportPage">
    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="20">

            <VerticalStackLayout Spacing="5" HorizontalOptions="Center" Margin="0,10">
                <Label Text="🪲" FontSize="50" HorizontalOptions="Center"/>
                <Label Text="Coś poszło nie tak?" FontSize="22" FontAttributes="Bold" HorizontalTextAlignment="Center" TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"/>
                <Label Text="Opisz napotkany problem, a nasz zespół zajmie się tym jak najszybciej." FontSize="14" TextColor="Gray" HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>

            <!--<VerticalStackLayout Spacing="5">
                <Label Text="Kategoria zgłoszenia" FontAttributes="Bold" FontSize="14" TextColor="{StaticResource Primary}"/>
                <Border StrokeShape="RoundRectangle 8" StrokeThickness="1" Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}" Padding="5,0">
                    <Picker x:Name="CategoryPicker" Title="Wybierz kategorię...">
                        <Picker.Items>
                            <x:String>Błąd aplikacji (Crash / Zawieszenie)</x:String>
                            <x:String>Problem z płatnością / koszykiem</x:String>
                            <x:String>Błąd w wyświetlaniu produktów</x:String>
                            <x:String>Problem z kontem użytkownika</x:String>
                            <x:String>Inne / Sugestia ulepszenia</x:String>
                        </Picker.Items>
                    </Picker>
                </Border>
            </VerticalStackLayout>-->

            <VerticalStackLayout Spacing="5">
                <Label Text="Krótki tytuł" FontAttributes="Bold" FontSize="14" TextColor="{StaticResource Primary}"/>
                <Border StrokeShape="RoundRectangle 8" StrokeThickness="1" Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}" Padding="10,0">
                    <Entry x:Name="BugTitleEntry" Placeholder="Np. Przycisk płatności nie reaguje" MaxLength="80"/>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="5">
                <Label Text="Szczegółowy opis błędu" FontAttributes="Bold" FontSize="14" TextColor="{StaticResource Primary}"/>
                <Border StrokeShape="RoundRectangle 8" StrokeThickness="1" Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}" Padding="10,5">
                    <Editor x:Name="BugDescriptionEditor" 
                            Placeholder="Opisz krok po kroku jak wywołać błąd oraz co dokładnie się stało..."
                            HeightRequest="150"
                            AutoSize="Disabled"
                            MaxLength="1000"/>
                </Border>
            </VerticalStackLayout>

            <Button Text="WYŚLIJ ZGŁOSZENIE"
                    CornerRadius="10"
                    HeightRequest="55"
                    FontAttributes="Bold"
                    FontSize="16"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    Clicked="OnSubmitBugClicked"
                    Margin="0,10,0,0"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>