<UserControl x:Class="SOK_WPF.Views.ChatUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SOK_WPF.Views"
             xmlns:conv="clr-namespace:SOK_WPF.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <ResourceDictionary>
            <conv:InitialsConverter x:Key="IConvert"/>
            <conv:NamesBoolConverter x:Key="NBConvert"/>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>

        <Image Source="/Assets/gg.jpg"/>
        <Grid RowDefinitions="3*,*">
            <ListView Grid.Row="0" ItemsSource="{Binding ChatHistory}" Background="#272343">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Focusable" Value="False"/>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#fffffe" CornerRadius="18">
                            <Grid x:Name="griddy" ColumnDefinitions="auto,*,auto" Margin="0,4">
                                <Border x:Name="AvatarBorder" Background="#ffd803" Width="32" Height="32" Margin="8,0" CornerRadius="30" Grid.Column="0">
                                    <TextBlock Text="{Binding [user], Converter={StaticResource IConvert}}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="12" FontWeight="DemiBold"/>
                                </Border>
                                <TextBlock x:Name="ContentTb" Text="{Binding [content]}" VerticalAlignment="Center" Grid.Column="1"/>
                            </Grid>
                        </Border>
                        <DataTemplate.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Value="False">
                                        <Condition.Binding>
                                            <MultiBinding Converter="{StaticResource NBConvert}">
                                                <MultiBinding.Bindings>
                                                    <Binding Path="[user]"/>
                                                    <Binding Path="DataContext.Acc.fullName" RelativeSource="{RelativeSource AncestorType={x:Type ListView}}"/>
                                                </MultiBinding.Bindings>
                                            </MultiBinding>
                                        </Condition.Binding>
                                    </Condition>
                                </MultiDataTrigger.Conditions>

                                <Setter TargetName="AvatarBorder" Property="Grid.Column" Value="2"/>
                                <Setter TargetName="AvatarBorder" Property="Background" Value="#bae8e8"/>
                                <Setter TargetName="ContentTb" Property="HorizontalAlignment" Value="Right"/>

                            </MultiDataTrigger>
                        </DataTemplate.Triggers>

                    </DataTemplate>

                </ListView.ItemTemplate>
            </ListView>
            <Grid Grid.Row="1" Grid.ColumnDefinitions="*,Auto" Margin="12">
                <TextBox Margin="0,0,8,0" HorizontalAlignment="Stretch" Padding="4" TextWrapping="Wrap"/>
                <Button Content="Wyślij" Width="80" Grid.Column="1"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
