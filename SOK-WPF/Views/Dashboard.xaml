<Page x:Class="SOK_WPF.Views.Dashboard"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SOK_WPF.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Dashboard">
    <Page.Resources>
        <Style TargetType="TextBlock" x:Key="InCircle">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="WrapWithOverflow"/>
            <Setter Property="Focusable" Value="False"/>
        </Style>
        <Style TargetType="Ellipse" x:Key="circle">
            <Setter Property="Margin" Value="16"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
        <Grid Width="260" Height="260" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid.InputBindings>
                <MouseBinding MouseAction="LeftClick" Command="{Binding GoToOrdersCommand}"/>
            </Grid.InputBindings>
            <Ellipse Fill="#f9bc60" Style="{DynamicResource circle}"/>
            <TextBlock Text="Uwagi do&#x0a;zamówień" Style="{DynamicResource InCircle}"/>
            <Grid VerticalAlignment="Top" HorizontalAlignment="Right">
                <Ellipse Fill="#272343" Margin="16" Width="56" Height="56"/>
                <TextBlock Text="256" Style="{DynamicResource InCircle}" Foreground="White"/>
            </Grid>
        </Grid>
        <Grid Width="260" Height="260" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid.InputBindings>
                <MouseBinding MouseAction="LeftClick" Command="{Binding GoToBugsReportsCommand}"/>
            </Grid.InputBindings>
            <Ellipse Fill="#f25f4c" Style="{DynamicResource circle}"/>
            <TextBlock Text="Zgłoszone&#x0a;błędy" Style="{DynamicResource InCircle}"/>
            <Grid VerticalAlignment="Top" HorizontalAlignment="Right">
                <Ellipse Fill="#272343" Margin="16" Width="56" Height="56" />
                <TextBlock Text="256" Style="{DynamicResource InCircle}" Foreground="White"/>
            </Grid>
        </Grid>
    </StackPanel>
</Page>
