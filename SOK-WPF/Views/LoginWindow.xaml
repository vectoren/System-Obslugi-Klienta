<Window x:Class="SOK_WPF.Views.LoginWindow"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SOK_WPF.Views"
      Background="#e3f6f5"
      mc:Ignorable="d"
      Height="450"
      Width="320"
        FontSize="16"
      Title="Login | SOK"
        ResizeMode="NoResize">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="boolToVis"/>
    </Window.Resources>
    <Grid>
        <Border Background="#bae8e8" Padding="8" HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="24">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" >

                <Border CornerRadius="16" Background="#ff8e3c" Margin="0,0,0,16" Visibility="{Binding IsLoginFailed, Converter={StaticResource boolToVis}}" Padding="4">
                    <StackPanel>
                        <Label Content="Wystąpił błąd logowania!"

                   Foreground="#272343"
                   HorizontalContentAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Label Content="Zaloguj się"
               FontSize="24"
               FontWeight="SemiBold"
               Foreground="#272343"
               HorizontalContentAlignment="Center"
               Margin="0,0,0,24"/>
                <StackPanel HorizontalAlignment="Left">
                    <Label Content="Adres e-mail:"
                   Foreground="#272343"
                   Margin="0,0,0,8"
                   Padding="0"/>
                    <TextBox Width="200" Margin="0,0,0,16" Text="{Binding Username}"/>

                    <Label Content="Hasło:"
                   Foreground="#272343"
                   Margin="0,0,0,8"
                   Padding="0"/>
                    <PasswordBox Width="200" Margin="0,0,0,16" x:Name="passwordBox"/>

                    <Button Content="Zaloguj się"
                        Height="40"
                        Margin="0,16,0,0"
                        Background="#ffd803"
                        Foreground="#272343"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Command="{Binding LoginCommand}"
                        CommandParameter="{Binding ElementName=passwordBox}"/>
                </StackPanel>
            </StackPanel>
        </Border>
        <Border Visibility="{Binding IsLogginingIn, Converter={StaticResource boolToVis}}" Background="#e3f6f5">
            <StackPanel 
                   VerticalAlignment="Center">
                <Label Content="Trwa logowanie..."
               FontSize="24"
               FontWeight="SemiBold"
               Foreground="#272343"
               HorizontalContentAlignment="Center"
               Margin="0,0,0,24"/>
                <MediaElement Source="./Assets/loading.mp4" LoadedBehavior="Play" MediaEnded="MediaElement_MediaEnded" Stretch="Uniform" Width="100"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
