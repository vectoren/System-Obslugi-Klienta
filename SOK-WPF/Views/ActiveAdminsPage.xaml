<Page x:Class="SOK_WPF.Views.ActiveAdminsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SOK_WPF.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      xmlns:vm="clr-namespace:SOK_WPF.ViewModels"
      Title="ActiveAdminsPage"
      Background="#fffffe">
    <Page.DataContext>
        <vm:ActiveAdminsVM/>
    </Page.DataContext>

    <StackPanel Margin="8">
        <TextBlock Text="Active Admins" FontSize="24" FontWeight="SemiBold" Foreground="#272343" TextWrapping="Wrap"/>


        <ListView ItemsSource="{Binding Admins}"
                      BorderThickness="0"
                      Margin="0"
                      Padding="0"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch">

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="#272343"
                                Padding="12"
                                Margin="0,5,0,5">
                        <StackPanel>
                            <DockPanel LastChildFill="False">
                                <TextBlock Text="{Binding Name}"
                                           FontWeight="SemiBold"
                                           Foreground="#fffffe"
                                           DockPanel.Dock="Left"/>

                                <TextBlock Text="{Binding Role}"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Background="#bae8e8"
                                           Foreground="#272343"
                                           Padding="4,2"
                                           DockPanel.Dock="Right"/>
                            </DockPanel>
                            <TextBlock Text="{Binding Email}" Foreground="#e3f6f5"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>

        </ListView>


    </StackPanel>
</Page>
