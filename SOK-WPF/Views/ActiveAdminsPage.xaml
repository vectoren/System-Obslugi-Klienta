<Page x:Class="SOK_WPF.Views.ActiveAdminsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SOK_WPF.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      xmlns:vm="clr-namespace:SOK_WPF.ViewModels"
      xmlns:conv="clr-namespace:SOK_WPF.Converters"
      Title="ActiveAdminsPage"
      Background="#fffffe">
    <Page.DataContext>
        <vm:ActiveAdminsVM/>
    </Page.DataContext>
    <Grid RowDefinitions="auto,*,*">
        <TextBlock Text="Dostępni Admini"
                   FontSize="24"
                   Margin="4"
                   FontWeight="SemiBold"
                   Foreground="#272343"
                   TextWrapping="Wrap"
                   Grid.Row="0"/>
        <ListView ItemsSource="{Binding Accounts}"
                  SelectedItem="{Binding ChatUCVM.Acc}"
                  BorderThickness="0"
                  Margin="0"
                  Padding="0"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Stretch" ScrollViewer.VerticalScrollBarVisibility="Auto" Grid.Row="1">

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="#272343"
                                Padding="12"
                                Margin="0,5,0,5"
                                CornerRadius="8">
                        <StackPanel>

                            <DockPanel LastChildFill="False">
                                <TextBlock Text="{Binding fullName}"
                                           FontWeight="SemiBold"
                                           Foreground="#fffffe"
                                           DockPanel.Dock="Left"/>
                                <Border DockPanel.Dock="Right" 
                                           Background="#bae8e8"
                                           CornerRadius="3">
                                    <TextBlock Text="Admin"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="#272343"
                                           Padding="4,2"/>
                                </Border>
                            </DockPanel>
                            <TextBlock Text="{Binding email}"
                                       Foreground="#e3f6f5"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>

        </ListView>
        <local:ChatUC Grid.Row="2" DataContext="{Binding ChatUCVM}"/>
    </Grid>
</Page>
